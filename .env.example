# /mel — Salvia marketing & signup site (Vite)
#
# All Vite env vars must be prefixed with VITE_ to be exposed to the browser.
# For local dev, copy this to `.env` and run `npm run dev`.

# Base URL of the Sal backend (handoff + pricing APIs).
# Dev: the local API server started by `cd ../sal && make dev`.
# Prod: e.g. https://api.salvia.nz
VITE_SAL_API_BASE=http://localhost:8080

# Address shown on the pricing page for "Talk to sales" links.
VITE_SUPPORT_EMAIL=sales@salvia.nz
